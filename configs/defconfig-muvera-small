# SPDX-License-Identifier: MIT
# Default config for the muvera-small reproducible byte-floor benchmark.
# Apply via:  make defconfig-muvera-small

CONFIG_MUVERA_SMALL=y

# Dataset
CONFIG_MUVERA_DATASET_SCIFACT=y

# Retrieval models
CONFIG_MUVERA_ENABLE_COLBERTV2=y
CONFIG_MUVERA_COLBERTV2_MODEL="lightonai/colbertv2.0"
CONFIG_MUVERA_ENABLE_BGE_SMALL=y
CONFIG_MUVERA_BGE_MODEL="BAAI/bge-small-en-v1.5"

# Benchmark blocks
CONFIG_MUVERA_SYSTEMS_BENCH=y
CONFIG_MUVERA_RETRIEVAL_BENCH=y
CONFIG_MUVERA_PLOTS=y
CONFIG_MUVERA_REPORT=y

# Output base. /data/knlp-key-results/ is Luis's results tree on prune.
# Set to anywhere writable; benchmark will mkdir -p as needed.
CONFIG_MUVERA_OUTPUT_BASE="/data/knlp-key-results"

# Systems benchmark
CONFIG_MUVERA_RECORD_SIZES="32 64 128 256 512 1024 2048 4096 8192 16384"
CONFIG_MUVERA_SYSTEMS_SMALL_RECORDS=1000000
CONFIG_MUVERA_SYSTEMS_RANDOM_READS=100000
CONFIG_MUVERA_SYSTEMS_TOPK=64
CONFIG_MUVERA_SYSTEMS_BATCH_SIZES="1 8 16 64 256"
CONFIG_MUVERA_SYSTEMS_PROJECTION_HIDDEN=4096

# Optional NVMe cold benchmark (off by default)
CONFIG_MUVERA_ENABLE_NVME_COLD_BENCH=n
CONFIG_MUVERA_NVME_BENCH_PATH="/mnt/nvme/muvera_bench"
CONFIG_MUVERA_NVME_LARGE_GB=128
CONFIG_MUVERA_NVME_RANDOM_READS=100000
CONFIG_MUVERA_ENABLE_DIRECT_IO=n
CONFIG_MUVERA_ENABLE_IO_URING=n

# Retrieval / FDE sweep
CONFIG_MUVERA_FDE_DIMS="512 1024 2048 4096 5120 8192 10240 20480"
CONFIG_MUVERA_FDE_R_VALUES="1 5 10"
CONFIG_MUVERA_FDE_KSIM_VALUES="2 3 4"
CONFIG_MUVERA_STORAGE_FORMATS="fp32 fp16 int8"
CONFIG_MUVERA_ENABLE_FAISS_PQ=y
CONFIG_MUVERA_PQ_CONFIGS="PQ256x8"

# Device
CONFIG_MUVERA_DEVICE="cuda:0"
