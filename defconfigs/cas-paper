# Cartridges-at-Scale (CAS) paper-faithful: full panel, collapse + rescue.
# Trains one cartridge per LongHealth patient, shows the isolated collapse,
# then the mixed-visibility rescue. Sized for one H100 (multi-day) or 4xH100.
# NOTE: the scale knobs below are the current best recipe; the exact
# convos/steps are finalized once the full Tier-2 run validates them.
# See research/cartridges_cas/README.md.
CONFIG_CARTRIDGES_CAS=y
CONFIG_CARTRIDGES_CAS_PAPER=y
CONFIG_CARTRIDGES_CAS_MODEL="Qwen/Qwen3-8B"
CONFIG_CARTRIDGES_CAS_NUM_PATIENTS=20
CONFIG_CARTRIDGES_CAS_CONVOS_PER_PATIENT=8000
CONFIG_CARTRIDGES_CAS_MIN_PROB_MASS="0.998"
CONFIG_CARTRIDGES_CAS_KV_TOKENS=512
CONFIG_CARTRIDGES_CAS_LR="1e-3"
CONFIG_CARTRIDGES_CAS_GLOBAL_BATCH=4
CONFIG_CARTRIDGES_CAS_STEPS=6000
CONFIG_CARTRIDGES_CAS_EPOCHS=14
CONFIG_CARTRIDGES_CAS_COMPILE_FLEX=y
CONFIG_CARTRIDGES_CAS_PHASE_SYNTH=y
CONFIG_CARTRIDGES_CAS_PHASE_TRAIN_ISOLATED=y
CONFIG_CARTRIDGES_CAS_PHASE_COLLAPSE=y
CONFIG_CARTRIDGES_CAS_PHASE_TRAIN_JOINT=y
CONFIG_CARTRIDGES_CAS_PHASE_RESCUE=y
