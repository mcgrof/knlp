CONFIG_KNLP_REPRODUCE_CARTRIDGES=y
CONFIG_KNLP_REPRODUCE_PROFILE="cartridges-vllm-tests"
CONFIG_KNLP_WORKTREE_ROOT=".."
CONFIG_KNLP_RESULTS_ROOT="./results/cartridges"
CONFIG_KNLP_BUILD_ROOT="./build/cartridges"
CONFIG_KNLP_VLLM_REPO="https://github.com/mcgrof/vllm.git"
CONFIG_KNLP_VLLM_REF="20260429-cartridges-code-only"
CONFIG_KNLP_VLLM_DIR="vllm"
CONFIG_KNLP_MODEL_LLAMA3B="meta-llama/Llama-3.2-3B-Instruct"
CONFIG_KNLP_TRANSFORMERS_VERSION="4.55.4"
CONFIG_KNLP_ENABLE_WANDB=n
CONFIG_KNLP_ENABLE_TRACKERIO=n
CONFIG_KNLP_UPLOAD_ARTIFACTS=n
CONFIG_KNLP_ALLOW_HARDWARE_SKIPS=y
CONFIG_KNLP_FAIL_ON_DIRTY_GIT=n
CONFIG_KNLP_REQUIRE_PINNED_REFS=n
CONFIG_KNLP_PARALLEL_GPUS="auto"
