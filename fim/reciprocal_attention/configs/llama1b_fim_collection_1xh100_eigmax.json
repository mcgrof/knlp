{
  "run_name": "llama1b-fim-collection-1xh100-eigmax",
  "model": {
    "hidden_size": 2048,
    "intermediate_size": 5632,
    "num_hidden_layers": 22,
    "num_attention_heads": 32,
    "num_key_value_heads": 4,
    "max_position_embeddings": 2048,
    "vocab_size": 50304,
    "rms_norm_eps": 1e-6,
    "rope_theta": 10000.0
  },
  "training": {
    "train_steps": 1000,
    "max_time": 900,
    "eval_interval": 100,
    "eval_batches": 2,
    "batch_size": 4,
    "gradient_accumulation_steps": 32,
    "learning_rate": 3e-4,
    "min_lr": 3e-5,
    "warmup_steps": 200,
    "weight_decay": 0.1,
    "max_grad_norm": 1.0,
    "seq_len": 1024,
    "bf16": true
  },
  "attention": {
    "impl": "sdpa",
    "backend": "auto",
    "record_backend": true,
    "capture_attention_stats": true
  },
  "ra": {
    "enabled": false,
    "layers": {}
  },
  "fim": {
    "enabled": true,
    "batches": 16,
    "candidate_low_threshold": 0.15,
    "candidate_keep_top_k_layers": 5,
    "select_top_heads": 28,
    "head_score_metric": "exact_eigmax",
    "output_file": "out/llama1b-matched/fim_summary_eigmax.json"
  },
  "tracking": {
    "wandb": false,
    "wandb_project": "llama1b-layer-ablation",
    "wandb_mode": "offline",
    "log_jsonl": true,
    "out_dir": "out/llama1b-matched"
  }
}
