{
  "run_name": "llama1b-ra-arm-a-fimtrace-1xh100-1hr",
  "model": {
    "hidden_size": 2048,
    "intermediate_size": 5632,
    "num_hidden_layers": 22,
    "num_attention_heads": 32,
    "num_key_value_heads": 4,
    "max_position_embeddings": 2048,
    "vocab_size": 50304,
    "rms_norm_eps": 1e-6,
    "rope_theta": 10000.0
  },
  "training": {
    "train_steps": 50000,
    "max_time": 3600,
    "eval_interval": 50,
    "eval_batches": 2,
    "batch_size": 4,
    "gradient_accumulation_steps": 32,
    "learning_rate": 3e-4,
    "min_lr": 3e-5,
    "warmup_steps": 1000,
    "weight_decay": 0.1,
    "max_grad_norm": 1.0,
    "seq_len": 1024,
    "bf16": true
  },
  "attention": {
    "impl": "sdpa",
    "backend": "auto",
    "record_backend": true,
    "capture_attention_stats": false
  },
  "ra": {
    "enabled": true,
    "alpha_std": 0.9375,
    "alpha_rec": 0.0625,
    "selection_file": "configs/ra_ablation_llama1b_arm_a_fimtrace.json"
  },
  "fim": {
    "enabled": false
  },
  "tracking": {
    "wandb": true,
    "wandb_project": "llama1b-layer-ablation",
    "wandb_mode": "online",
    "log_jsonl": true,
    "out_dir": "out/llama1b-matched"
  }
}
