{
  "run_name": "llama1b-baseline-b200x4-smoke",
  "model": {
    "hidden_size": 2048,
    "intermediate_size": 5632,
    "num_hidden_layers": 22,
    "num_attention_heads": 32,
    "num_key_value_heads": 4,
    "max_position_embeddings": 2048,
    "vocab_size": 50304,
    "rms_norm_eps": 1e-6,
    "rope_theta": 10000.0
  },
  "training": {
    "train_steps": 8,
    "max_time": 180,
    "eval_interval": 4,
    "eval_batches": 1,
    "batch_size": 4,
    "gradient_accumulation_steps": 8,
    "learning_rate": 3e-4,
    "min_lr": 3e-5,
    "warmup_steps": 1000,
    "weight_decay": 0.1,
    "max_grad_norm": 1.0,
    "seq_len": 1024,
    "bf16": true
  },
  "attention": {
    "impl": "sdpa",
    "backend": "auto",
    "record_backend": true,
    "capture_attention_stats": false
  },
  "ra": {
    "enabled": false,
    "layers": {}
  },
  "fim": {
    "enabled": false
  },
  "tracking": {
    "wandb": false,
    "wandb_project": "llama1b-ra-surgical-b200x4",
    "wandb_mode": "offline",
    "log_jsonl": true,
    "out_dir": "out/llama1b-matched"
  }
}
