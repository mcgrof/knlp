# GPT-2 RGSA Dense Ablation on TinyStories
# Ablation: RGSA with routing DISABLED (dense attention only)
# Router parameters still exist for parameter count control
# All other settings MUST match gpt2-tinystories-rgsa exactly
CONFIG_MODEL_MODE_SINGLE=y
CONFIG_MODEL_SELECT_GPT2=y
CONFIG_MODEL_GPT2=y
CONFIG_MODEL="gpt2"

# GPT-2 Model Configuration - 124M base model
CONFIG_GPT2_MODEL_124M=y
CONFIG_GPT2_MODEL_NAME="gpt2"

# Dataset - TinyStories (compact, good for ablations)
CONFIG_GPT2_DATASET_TINYSTORIES=y
CONFIG_GPT2_DATASET="tinystories"

# Training parameters - MUST MATCH BASELINE/RGSA CONFIG
CONFIG_GPT2_BLOCK_SIZE=1024
CONFIG_GPT2_MAX_TIME=2700
CONFIG_GPT2_EVAL_INTERVAL=50
CONFIG_GPT2_EVAL_SAMPLES=200
CONFIG_GPT2_LOG_INTERVAL=10
CONFIG_GPT2_WARMUP_STEPS=200
CONFIG_GPT2_DECAY_LR=y
CONFIG_GPT2_MIN_LR="6e-5"
CONFIG_GPT2_DROPOUT="0.1"
CONFIG_GPT2_FLASH_ATTENTION=n
CONFIG_GPT2_COMPILE=y
CONFIG_GPT2_WEIGHT_TYING=y
CONFIG_GPT2_BIAS=y
CONFIG_GPT2_CUDNN_BENCHMARK=y
CONFIG_GPT2_TF32_ALLOWED=y
CONFIG_GPT2_AMP_DTYPE="bfloat16"

# Batch size and training - MUST MATCH BASELINE/RGSA CONFIG
CONFIG_BATCH_SIZE=8
CONFIG_GRADIENT_ACCUMULATION=30
CONFIG_NUM_EPOCHS=10
CONFIG_LEARNING_RATE="6e-4"
CONFIG_WEIGHT_DECAY="0.1"
CONFIG_NUM_WORKERS=16
CONFIG_DEVICE="cuda"
CONFIG_DATA_DIR="./gpt2/data"
CONFIG_PIN_MEMORY=y
CONFIG_PERSISTENT_WORKERS=y
CONFIG_PREFETCH_FACTOR=4

# Seed for reproducibility - MUST MATCH BASELINE/RGSA CONFIG
CONFIG_SEED=42

# Optimizer - AdamWSPAM
CONFIG_OPTIMIZER_MODE_SINGLE=y
CONFIG_OPTIMIZER_SELECT_ADAMWSPAM=y
CONFIG_OPTIMIZER="adamwspam"

# SPAM Configuration
CONFIG_SPAM_THETA="50.0"
CONFIG_SPAM_ENABLE_CLIP=y
CONFIG_SPAM_SPIKE_THRESHOLD="2.0"
CONFIG_SPAM_PERIODIC_RESET=y
CONFIG_SPAM_INTERVAL=1000
CONFIG_SPAM_WARMUP=y
CONFIG_SPAM_WARMUP_STEPS=200

# Pruning - Disabled
CONFIG_PRUNING_MODE_NONE=y
CONFIG_PRUNING_METHOD="none"

# RGSA Enabled with DENSE ABLATION
# Router modules exist but routing is skipped (dense_mode=True)
CONFIG_ENABLE_RA_MLA=n
CONFIG_GPT2_KNLP=n
CONFIG_ENABLE_RGSA=y
CONFIG_RGSA_CHUNK_SIZE=64
CONFIG_RGSA_ROUTING_DIM=32
CONFIG_RGSA_TOP_B=8
CONFIG_RGSA_LOCAL_WINDOW=256
CONFIG_RGSA_ROUTING_LOSS_WEIGHT="0.1"
# Ablation: disable routing (dense attention with router params)
CONFIG_RGSA_DENSE_MODE=y

# Experiment Tracking - W&B enabled
CONFIG_ENABLE_TRACKIO=n
CONFIG_ENABLE_WANDB=y
CONFIG_TRACKER_PROJECT="gpt2-rgsa-compare"

# Checkpointing
CONFIG_MIXED_PRECISION=y
CONFIG_GPU_WARMUP=y
CONFIG_SAVE_CHECKPOINT=y
CONFIG_CHECKPOINT_INTERVAL=500

# Memory Optimizations
CONFIG_PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True"
